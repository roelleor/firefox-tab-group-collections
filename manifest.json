{
  "manifest_version": 2,
  "name": "Tab Group Collections",
  "version": "1.4.1",
  "description": "Add collection-level organization on top of native Firefox tab groups.",
  "icons": {
    "48": "src/icons/tab-group-collections.svg",
    "96": "src/icons/tab-group-collections.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "sessions",
    "tabGroups",
    "browserSettings"
  ],
  "background": {
    "scripts": ["src/shared.js", "src/background.js"]
  },
  "browser_action": {
    "default_title": "Tab Group Collections",
    "default_icon": "src/icons/tab-group-collections.svg",
    "default_popup": "src/popup.html"
  },
  "sidebar_action": {
    "default_title": "Tab Group Collections",
    "default_panel": "src/sidebar.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{E6A63954-988C-4D10-BB29-754B8F7EAB4E}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
